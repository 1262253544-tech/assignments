#include <stdio.h>

int main() {
    float basicPay, hra, da, grossSalary, profTax, netSalary;

    // 1. Input basic pay
    printf("Enter Basic Pay: ");
    scanf("%f", &basicPay);

    // 2. Define allowances (Assuming HRA=20%, DA=50% of basic)
    hra = 0.20 * basicPay;
    da = 0.50 * basicPay;

    // 3. Calculate Gross Salary
    grossSalary = basicPay + hra + da;

    // 4. Calculate 2% Professional Tax
    profTax = 0.02 * grossSalary;

    // 5. Calculate Net Salary
    netSalary = grossSalary - profTax;

    // 6. Display Results
    printf("\n--- Salary Slip ---\n");
    printf("Basic Pay:       %.2f\n", basicPay);
    printf("HRA (20%%):       %.2f\n", hra);
    printf("DA (50%%):        %.2f\n", da);
    printf("Gross Salary:    %.2f\n", grossSalary);
    printf("Prof. Tax (2%%):  %.2f\n", profTax);
    printf("-------------------\n");
    printf("Net Salary:      %.2f\n", netSalary);
    printf("-------------------\n");

    return 0;
}
